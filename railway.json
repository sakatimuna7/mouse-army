{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npx turbo build --filter=server"
  },
  "deploy": {
    "startCommand": "node apps/server/dist/network/index.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100
  }
}
